<!DOCTYPE html>
<html>
<head>
  <title>Vineyard Monitor</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  <style>
    .toast {
      position: fixed;
      bottom: 20px;
      right: 20px;
      padding: 12px 24px;
      border-radius: 8px;
      color: white;
      z-index: 1000;
      animation: slideIn 0.3s ease;
    }
    .toast.success { background-color: #10b981; }
    .toast.error { background-color: #ef4444; }
    .toast.info { background-color: #3b82f6; }
    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    .btn-primary {
      background-color: #3b82f6;
      color: white;
      padding: 8px 16px;
      border-radius: 8px;
      transition: background-color 0.2s;
      border: none;
      cursor: pointer;
    }
    .btn-primary:hover {
      background-color: #2563eb;
    }
    .btn-danger {
      background-color: #ef4444;
      color: white;
      padding: 8px 16px;
      border-radius: 8px;
      transition: background-color 0.2s;
      border: none;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
    }
    .btn-danger:hover {
      background-color: #dc2626;
    }
    .btn-link {
      background-color: #f3f4f6;
      color: #374151;
      padding: 8px 16px;
      border-radius: 8px;
      transition: all 0.2s;
      text-decoration: none;
      display: inline-block;
    }
    .btn-link:hover {
      background-color: #e5e7eb;
      color: #1f2937;
    }
    .btn-sm {
      padding: 4px 12px;
      font-size: 0.875rem;
    }
    
    .pagination {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 24px;
      flex-wrap: wrap;
    }
    .pagination a, .pagination span {
      padding: 8px 12px;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      text-decoration: none;
      color: #374151;
      transition: all 0.2s;
    }
    .pagination a:hover {
      background-color: #f3f4f6;
      border-color: #9ca3af;
    }
    .pagination .current {
      background-color: #3b82f6;
      border-color: #3b82f6;
      color: white;
    }
    .pagination .disabled {
      color: #9ca3af;
      cursor: not-allowed;
    }
    .pagination .prev, .pagination .next {
      font-weight: 500;
    }
  </style>
</head>

<body class="bg-gray-100">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Vineyard Monitoring System</h1>
    
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-700 mb-4">Создать новое видео</h2>
      
      <div class="flex gap-4">
        <input type="text" id="videoName" placeholder="Название видео" 
               class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
        <button id="createVideoBtn" class="btn-primary">
          Создать видео
        </button>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold text-gray-700 mb-4">Список видео</h2>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
              <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Название</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Статус</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ряды</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Прогресс</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Создано</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Действия</th>
              </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200" id="videosList">
            <% @videos.each do |video| %>
              <tr class="hover:bg-gray-50" data-video-id="<%= video.id %>">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= video.id %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= video.name %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                    <%= status_color(video.status) %>">
                    <%= video.status %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= video.video_shards.count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="w-full bg-gray-200 rounded-full h-2.5">
                    <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= video.processing_progress %>%"></div>
                  </div>
                  <span class="text-xs text-gray-500"><%= video.processing_progress %>%</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= time_ago_in_words(video.created_at) %> назад
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= link_to "Подробнее", video_path(video), class: "btn-link btn-sm inline-block mr-2" %>
                  <%= button_to destroy_video_path(video), 
                        method: :delete, 
                        form: { style: "display: inline-block", data: { turbo: false } },
                        data: { confirm: "Вы уверены? Видео и все его ряды будут удалены безвозвратно." },
                        class: "btn-danger btn-sm inline-block" do %>
                    Удалить
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <div class="pagination">
        <%== @pagy.series_nav(:bootstrap, slots: 7) %>
      </div>

      <div class="text-center text-sm text-gray-500 mt-4">
        Показано <%= @pagy.from %> - <%= @pagy.to %> из <%= @pagy.count %> видео
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const createBtn = document.getElementById('createVideoBtn');
      const videoNameInput = document.getElementById('videoName');
      const uploadTestVideoBtn = document.getElementById('uploadTestVideoBtn');
      const testVideoFileInput = document.getElementById('testVideoFile');
      
      function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        toast.textContent = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
      }
      
      createBtn.addEventListener('click', async () => {
        const name = videoNameInput.value.trim();
        
        try {
          const response = await fetch('/api/videos', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
            },
            body: JSON.stringify({ name: name || null })
          });
          
          const data = await response.json();
          
          if (response.ok) {
            showToast(`Видео создано! ID: ${data.id}`, 'success');
            videoNameInput.value = '';
            setTimeout(() => window.location.reload(), 1500);
          } else {
            showToast(`Ошибка: ${data.error}`, 'error');
          }
        } catch (error) {
          console.error('Error:', error);
          showToast('Ошибка создания видео', 'error');
        }
      });

      uploadTestVideoBtn.addEventListener('click', async () => {
        const file = testVideoFileInput.files[0];
        if (!file) {
          showToast('Выберите видеофайл', 'error');
          return;
        }

        uploadTestVideoBtn.disabled = true;
        uploadTestVideoBtn.textContent = 'Загрузка...';

        try {
          const createResponse = await fetch('/api/videos', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
            },
            body: JSON.stringify({ name: `Тестовая загрузка: ${file.name}` })
          });

          const createData = await createResponse.json();
          if (!createResponse.ok) {
            throw new Error(Array.isArray(createData.error) ? createData.error.join(', ') : (createData.error || 'Не удалось создать видео'));
          }

          const formData = new FormData();
          formData.append('shard_index', '1');
          formData.append('video', file);

          const uploadResponse = await fetch(`/api/videos/${createData.id}/upload_shard`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
            },
            body: formData
          });

          const uploadData = await uploadResponse.json();
          if (!uploadResponse.ok) {
            throw new Error(Array.isArray(uploadData.error) ? uploadData.error.join(', ') : (uploadData.error || 'Не удалось загрузить файл'));
          }

          showToast(`Файл загружен. Видео ID: ${createData.id}`, 'success');
          testVideoFileInput.value = '';
          setTimeout(() => window.location.reload(), 1500);
        } catch (error) {
          console.error('Upload test video error:', error);
          showToast(`Ошибка загрузки: ${error.message}`, 'error');
        } finally {
          uploadTestVideoBtn.disabled = false;
          uploadTestVideoBtn.textContent = 'Загрузить файл (тест)';
        }
      });
    });
  </script>
</body>
</html>