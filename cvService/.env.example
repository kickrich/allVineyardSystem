# Локальный запуск: скопируйте в .env (рядом с этим файлом).
# Без models/best.onnx сервис всё равно отвечает (заглушка, метрики = 0).
# Явная ошибка вместо заглушки: CV_STRICT_MODEL=1
# CV_DUMMY_INFERENCE=true — лишь доп. лог «режим заглушки» (поведение то же без весов).
CV_DUMMY_INFERENCE=true

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vineyard-videos
MINIO_REGION=us-east-1
MINIO_SECURE=false
