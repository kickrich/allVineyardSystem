# MinIO (docker-compose: порт 9000 API, 9001 консоль; ROOT = minioadmin / minioadmin; бакет = vineyard-videos как в cv)
S3_BUCKET=vineyard-videos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
# С хоста (rails s) к MinIO на localhost:
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
S3_FORCE_PATH_STYLE=true

# URL VineyardApp (отправка видео из backend)
VINEYARD_APP_URL=http://127.0.0.1:3000
# Таймаут и ретраи отправки shard'ов в VineyardApp (на случай временных 404/timeout при старте/перегрузке)
VINEYARD_APP_UPLOAD_TIMEOUT_SECONDS=600
VINEYARD_APP_UPLOAD_RETRY_ATTEMPTS=4
VINEYARD_APP_UPLOAD_RETRY_DELAY_SECONDS=3
# URL backend для колбэков; по умолчанию порт из Puma
BACKEND_PUBLIC_URL=http://127.0.0.1:3001
PORT=3001

FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Тестовые видео для фронта (VITE_USE_TEST_MISSION_SHARD_VIDEOS): папка внутри монорепо, относительно backend/
# Положите файлы *.webm / *.mp4; по алфавиту: 1-й файл = ряд 1, 2-й = ряд 2, …
TEST_MISSION_SHARD_VIDEOS_DIR=../test_mission_shard_videos
# В production включайте явно (в development API доступен и без этого):
# ENABLE_TEST_MISSION_VIDEO_SHARDS=true
